# Postgres warehouse connection (Neon)
# Same database your backend uses — set this to the same WAREHOUSE_DATABASE_URL value.
WAREHOUSE_DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Default folder the maintenance page points at when scanning for txt files.
# This path lives on the lab computer's shared drive.
READINESS_SCREEN_OUTPUT_DIR=D:/Athletic Screen 2.0/Output Files

# Folder where raw *_Power.txt files live (used by power_analysis).
# In most setups this is the same as READINESS_SCREEN_OUTPUT_DIR.
READINESS_SCREEN_POWER_DIR=D:/Athletic Screen 2.0/Output Files

# Sampling rate for the force plate power signal (Hz).
# Default 1000 Hz matches the backend's athleticScreen power_analysis.
POWER_SAMPLE_RATE_HZ=1000

# Flask
FLASK_PORT=5057
FLASK_DEBUG=0
